# ==================================================
# Server Configuration
# ==================================================
# Docker image tag: "latest" for production, "dev" for development
IMAGE_TAG=latest

# SA-MP server port
SAMP_PORT=7777

# Container names
CONTAINER_NAME=ulp-gamemode
MYSQL_CONTAINER_NAME=ulp-mysql

# ==================================================
# MySQL Configuration
# ==================================================
MYSQL_ROOT_PASSWORD=tu_contraseña_root_segura
MYSQL_USER=samp
MYSQL_PASSWORD=tu_contraseña_usuario_segura
MYSQL_DATABASE=database_samp
MYSQL_HOST=mysql

# Internal MySQL port (inside the container, always 3306)
MYSQL_PORT=3306

# External MySQL port (for accessing from the host)
# Production: 3306 (if no conflict)
# Development: 3308 (to avoid conflict with production)
MYSQL_EXTERNAL_PORT=3306
