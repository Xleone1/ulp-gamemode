#include <open.mp>
#include <streamer>

#define MAX_OBJETOS_COUNT 5000

new Objeto[MAX_OBJETOS_COUNT][3];//ID Mundo Interior
new MAX_OBJETOS;

forward CreateDynamicObjectFs(modelid, Float:x, Float:y, Float:z, Float:rx, Float:ry, Float:rz, worldid, interiorid);
forward CreateObjectEx(modelid, Float:x, Float:y, Float:z, Float:rx, Float:ry, Float:rz, Float:DrawDistance);

public CreateDynamicObjectFs(modelid, Float:x, Float:y, Float:z, Float:rx, Float:ry, Float:rz, worldid, interiorid)
{
	if(MAX_OBJETOS < MAX_OBJETOS_COUNT)
	{
		Objeto[MAX_OBJETOS][0] = CreateDynamicObject(modelid, x, y, z, rx, ry, rz, worldid, interiorid);
		Objeto[MAX_OBJETOS][1] = worldid;
		Objeto[MAX_OBJETOS][2] = interiorid;
		MAX_OBJETOS++;
		return Objeto[MAX_OBJETOS-1][0];
	}
	else return printf("MAPEOS: Object overload: Se intento crear mas objetos de lo maximo preestablecido (%i)", MAX_OBJETOS_COUNT);
}

public CreateObjectEx(modelid, Float:x, Float:y, Float:z, Float:rx, Float:ry, Float:rz, Float:DrawDistance)
{
	if(MAX_OBJETOS < MAX_OBJETOS_COUNT)
	{
		Objeto[MAX_OBJETOS][0] = CreateObject(modelid, x, y, z, rx, ry, rz, DrawDistance);
		MAX_OBJETOS++;
		SetSVarInt("Static_Objects", GetSVarInt("Static_Objects")+1);
		return Objeto[MAX_OBJETOS-1][0];
	}
	else return printf("MAPEOS: Object overload: Se intento crear mas objetos de lo maximo preestablecido (%i)", MAX_OBJETOS_COUNT);
}

