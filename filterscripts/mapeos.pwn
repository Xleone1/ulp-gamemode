public OnPlayerConnect(playerid)
{
	RemoveBuildings(playerid);
	return 1;
}

public OnPlayerCommandText(playerid, cmdtext[])
{
	if (strfind(cmdtext, "/iro ", true) == 0)
	{
	    if (!IsPlayerAdmin(playerid)) return 0;
	    new objetoid = strval(cmdtext[5]);
	    new Float:Pos[3] = {0.0,0.0,3.0}; GetDynamicObjectPos(Objeto[objetoid][0], Pos[0], Pos[1], Pos[2]);
	    SetPlayerPos(playerid, Pos[0], Pos[1], Pos[2]);
	    if (Objeto[objetoid][1] != -1) SetPlayerVirtualWorld(playerid, Objeto[objetoid][1]);
	    if (Objeto[objetoid][2] != -1) SetPlayerInterior(playerid, Objeto[objetoid][2]);
	    return 1;
	}
	return 0;
}
