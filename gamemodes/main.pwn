			  		if (cmdtext[10] == '\0') return SendInfoMessage(playerid, 0, "0", "Uso:\n/Bolsillos [ID]");
				    if ( playerid == strval(cmdtext[11]) )
				    {
				        Acciones(playerid, 8, "se revisa en los bolsillos");
