									format(MsgGanzuasToPlayer, sizeof(MsgGanzuasToPlayer), "El mecĂˇnico %s quiere venderte 5 ganzuas por $%i usa (/Aceptar Ganzuas)", PlayersDataOnline[playerid][NameOnlineFix], dinero_ganzuas);

		                            SendInfoMessage(playerid, 3, "0", MsgGanzuas);
		                            SendInfoMessage(playerid_ganzuas, 3, "0", MsgGanzuasToPlayer);

