			new PickupOrCheck = PlayersDataOnline[playerid][SaveAfterAgenda][3];
			if(!NegociosModelos[bizzType][bizzModel][InteriorId]) return Error(playerid, "El modelo de negocio que estaba editando ya no existe!");
			if(response){
				if(strlen(inputtext) < 1){
					SendInfoMessage(playerid, 0, "", "Ingrese un valor");
					return ShowBizzModelsOptsSub(playerid, bizzType, bizzModel, PickupOrCheck, option);
				}
				new Float:getValue = floatstr(inputtext);
				if(PickupOrCheck == 0){
					if(option == 0) NegociosModelos[bizzType][bizzModel][PosInX] = getValue;
					else if(option == 1) NegociosModelos[bizzType][bizzModel][PosInY] = getValue;
					else if(option == 2) NegociosModelos[bizzType][bizzModel][PosInZ] = getValue;
					else if(option == 3) NegociosModelos[bizzType][bizzModel][PosInZZ] = getValue;
					else if(option == 4){
						if(strval(inputtext) >= 1){
							NegociosModelos[bizzType][bizzModel][InteriorId] = strval(inputtext);
						}
						else SendInfoMessage(playerid, 0, "", "El interior_id debe ser un numero mayor o igual a 1...");
					}
					ShowPlayerBizzTypesModelsOptions(playerid, bizzType, bizzModel, 1);
				}
				else{
					if(option == 0) NegociosModelos[bizzType][bizzModel][PosInX_PC] = getValue;
					else if(option == 1) NegociosModelos[bizzType][bizzModel][PosInY_PC] = getValue;
					else if(option == 2) NegociosModelos[bizzType][bizzModel][PosInZ_PC] = getValue;
					ShowPlayerBizzTypesModelsOptions(playerid, bizzType, bizzModel, 2);
					UpdateAllBizzModelCheckPoint(playerid, bizzType, bizzModel);
				}
				UpdateBizzTypeModelPickup(bizzType, bizzModel);
				SaveDataBizzModel(bizzType, bizzModel);
			}
			else{
				if(PickupOrCheck == 0) ShowPlayerBizzTypesModelsOptions(playerid, bizzType, bizzModel, 1);
				else ShowPlayerBizzTypesModelsOptions(playerid, bizzType, bizzModel, 2);
			}
			return 1;
		}
