											format(MsgServicio, sizeof(MsgServicio), "** El medico %s esta de servicio. Llamar al 106.", PlayersDataOnline[playerid][NameOnlineFix]);
										}
										else
										{
											format(MsgServicio, sizeof(MsgServicio), "** El medico %s esta de servicio. Llamar al 105.", PlayersDataOnline[playerid][NameOnlineFix]);
										}
									}
								}

		      					SendInfoMessage(playerid, 2, "0", "Ahora estas de servicio.");
		                        PlayersDataOnline[playerid][StateJob] = true;
							}
