						format(MsgCarteraMe, sizeof(MsgCarteraMe), "le enseÄa su cartera a %s", PlayersDataOnline[strval(cmdtext[9])][NameOnlineFix]);
				        Acciones(playerid, 8, MsgCarteraMe);
						ShowCarteraToPlayer(playerid, strval(cmdtext[9]));
