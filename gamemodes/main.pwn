				else if (strcmp("/Re", cmdtext, true) == 0) return SendSyntaxError(playerid, "Re", "Re 12 o /Re 12 PG");
				else if (strfind(cmdtext, "/Re", true) == 0 && (cmdtext[3] == ' ' || cmdtext[3] == '\0'))
				{
					if (cmdtext[3] == '\0') return SendInfoMessage(playerid, 0, "0", "Uso:\n/Re [ID] [Razon]");
