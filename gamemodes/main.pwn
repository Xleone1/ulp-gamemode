						GivePlayerWeaponEx(playerid, IdArmasTraficantes[listitem], MunicionArmasTraficantes[listitem]);
						format(MsgCrearArma, sizeof(MsgCrearArma), "Has creado un %s con municion %i por %i de materiales", SlotNameWeapon[IdArmasTraficantes[listitem]], MunicionArmasTraficantes[listitem], MaterialesArmasTraficantes[listitem]);
					}
					else
					{
