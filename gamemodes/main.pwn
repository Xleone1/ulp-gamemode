			        SetPlayerPos(playerid, Mapeo[mapeoid][PosX], Mapeo[mapeoid][PosY], Mapeo[mapeoid][PosZ]);
			        SetPlayerVirtualWorldEx(playerid, Mapeo[mapeoid][Mundo]);
			        SetPlayerInteriorEx(playerid, Mapeo[mapeoid][Interior]);
