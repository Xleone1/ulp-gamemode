			    					{
										if ( DataCars[vehicleIndex][Gas] < MAX_GAS_VEHICLE )
										{
										    new GasToFill;
										    if ( strcmp("/Llenar Deposito", cmdtext, true, 16) == 0 && strlen(cmdtext) == 16 )
										    {
												GasToFill = MAX_GAS_VEHICLE - DataCars[vehicleIndex][Gas];
										    }
										    else
										    {
										        GasToFill = strval(cmdtext[GetPosSpace(cmdtext, 2)]);
											}
