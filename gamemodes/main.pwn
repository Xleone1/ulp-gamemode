SetCameraLogin(playerid, nextcamera, avanze)
{
	if ( avanze )
	{
		nextcamera++;
	}
	else
	{
	    nextcamera--;
	}

	if ( nextcamera > MAX_CAMERAS_LOGIN )
	{
	    nextcamera = 0;
	}
	else if ( nextcamera < 0 )
	{
	    nextcamera = MAX_CAMERAS_LOGIN;
	}
	PlayersData[playerid][CameraLogin] = nextcamera;

	SetPlayerPos(playerid, CamerasLogin[nextcamera][PlayerPosLogin][0], CamerasLogin[nextcamera][PlayerPosLogin][1], CamerasLogin[nextcamera][PlayerPosLogin][2]);
	SetPlayerCameraPos(playerid, 	CamerasLogin[nextcamera][CamerasPosLogin][0], CamerasLogin[nextcamera][CamerasPosLogin][1], CamerasLogin[nextcamera][CamerasPosLogin][2]);
	SetPlayerCameraLookAt(playerid, CamerasLogin[nextcamera][CamerasLookLogin][0], CamerasLogin[nextcamera][CamerasLookLogin][1], CamerasLogin[nextcamera][CamerasLookLogin][2]);
}

MostrarHora(Accion, playerid)
{
	new Hora, Minutos, Segundos;
	new Ano, Mes, Dia;

	gettime( Hora, Minutos, Segundos );
	getdate(Ano, Mes, Dia);
	Mes--;

	new FechaHoraFormateada[150];

	if ( Accion == 0 )
	{
	    if ( PlayersData[playerid][Jail] == 0 )
	    {
			format(FechaHoraFormateada, sizeof(FechaHoraFormateada), "~W~%i ~B~%s ~W~%i ~N~Son las %i~R~:~W~%i~R~:~W~%i", Dia, Meses[Mes], Ano, Hora, Minutos, Segundos);
		}
		else
		{
			format(FechaHoraFormateada, sizeof(FechaHoraFormateada), "~W~%i ~B~%s ~W~%i ~N~Son las %i~R~:~W~%i~R~:~W~%i~N~~R~Jail: ~W~%i sec", Dia, Meses[Mes], Ano, Hora, Minutos, Segundos, PlayersData[playerid][Jail] - gettime());
		}
		Acciones(playerid, 8, "mira la hora");
		GameTextForPlayer(playerid, FechaHoraFormateada, 5000, 1 );
	}
	else if ( Accion == 1 || Accion == 2  )
	{
		if (Bonus)
		format(FechaHoraFormateada, sizeof(FechaHoraFormateada), "~W~Hora de la Paga!~N~%i ~B~%s ~W~%i ~N~Son las %i~R~:~W~%i~R~:~W~%i~N~~r~B~g~O~b~N~r~U~b~S~p~!", Dia, Meses[Mes], Ano, Hora, Minutos, Segundos);
     	else
	    format(FechaHoraFormateada, sizeof(FechaHoraFormateada), "~W~Hora de la Paga!~N~%i ~B~%s ~W~%i ~N~Son las %i~R~:~W~%i~R~:~W~%i", Dia, Meses[Mes], Ano, Hora, Minutos, Segundos);
		new TimeNow = gettime();
		new MensajeBanco[5][70];
		new paga;
		new Intereses;
		new Float:impuestos;
		new Float:impuestosCasa, Float:impuestosNegocio, Float:impuestosVehiculo;
        new houseid;
		new Float:Xpaga, Float:Ypaga, Float:Zpaga;
	    for (new i = 0; i < MAX_PLAYERS; i++)
	    {
			if(!IsPlayerLogued(i)) continue;
			if ( ((TimeNow - PlayersDataOnline[i][IsPagaO]) + PlayersData[i][IsPaga]) > 1200 || Accion == 2)
			{
			    GameTextForPlayer(i, FechaHoraFormateada, 6000, 1);

				Intereses = PlayersData[i][Banco] / 2000;

                if (Bonus)
				{
		   			format(MensajeBanco[0], 70, "Balance Actual: $%i | Paga: $%i (+%i BONUS)", PlayersData[i][Banco], FaccionData[PlayersData[i][Faccion]][Paga][PlayersData[i][Rango]], Bonus);
					paga = FaccionData[PlayersData[i][Faccion]][Paga][PlayersData[i][Rango]] + Intereses + Bonus;
				}
				else
				{
		   			format(MensajeBanco[0], 70, "Balance Actual: $%i | Paga: $%i", PlayersData[i][Banco], FaccionData[PlayersData[i][Faccion]][Paga][PlayersData[i][Rango]]);
					paga = FaccionData[PlayersData[i][Faccion]][Paga][PlayersData[i][Rango]] + Intereses;
				}
		   		format(MensajeBanco[1], 70, "Intereses Bancarios: $%i", Intereses);
		   		format(MensajeBanco[2], 70, "Nuevo Balance: $%i (+$%i)", PlayersData[i][Banco] + paga, paga);

    			SendInfoMessage(i, 1, " ", "|___________________  Banco ___________________|");
    			SendInfoMessage(i, 1, MensajeBanco[0], "Banco: ");
    			SendInfoMessage(i, 1, MensajeBanco[1], "Banco: ");
    			SendInfoMessage(i, 1, MensajeBanco[2], "Banco: ");

				//Pagar
				PlayersData[i][Banco] += paga;
				//Impuestos
				if(Accion == 1)
				{
					//Alquiler
					if ( PlayersData[i][Alquiler] != -1 )
					{
						SendInfoMessage(i, 1, " ", "|_____________________ Alquiler ____________________|");
						if ( HouseData[PlayersData[i][Alquiler]][PriceRent] <= PlayersData[i][Banco] )
						{
							format(MensajeBanco[3], 70, "{"COLOR_ROJO"}-{"COLOR_VERDE"}$%i", HouseData[PlayersData[i][Alquiler]][PriceRent]);
							SendInfoMessage(i, 1, MensajeBanco[3], "Alquiler: ");
							HouseData[PlayersData[i][Alquiler]][Deposito] = HouseData[PlayersData[i][Alquiler]][Deposito] + HouseData[PlayersData[i][Alquiler]][PriceRent];
							SaveHouse(PlayersData[i][Alquiler]);
							impuestos += HouseData[PlayersData[i][Alquiler]][PriceRent];
						}
						else
						{
							PlayersData[i][Alquiler] = -1;
							PlayersData[i][House] 	= -1;
							SendInfoMessage(i, 3, "0", "Has sido desalojado de su alquiler, por falta de dinero en el banco!");
						}
					}
					//Casa
					if ( PlayersData[i][House] != -1 || PlayersData[i][Alquiler] != -1 )
					{
						if ( PlayersData[i][Alquiler] != -1 )
						{
							houseid = PlayersData[i][Alquiler];
						}
						else
						{
							houseid = PlayersData[i][House];
						}
						impuestosCasa = floatdiv(floatmul(HouseData[houseid][Price], alicuotaCasas), 100);
						impuestos += impuestosCasa;
						FaccionData[GOBIERNO][Deposito] = FaccionData[GOBIERNO][Deposito] + floatround(impuestosCasa);
						format(MensajeBanco[3], 70, "{"COLOR_ROJO"}-{"COLOR_VERDE"}$%i", floatround(impuestosCasa));
						SendInfoMessage(i, 1, MensajeBanco[3], "Casa: ");

						if ( impuestos > PlayersData[i][Banco] )
						{
							if ( PlayersData[i][Alquiler] != -1 )
							{
								PlayersData[i][Alquiler] = -1;
								PlayersData[i][House] 	= -1;
								SendInfoMessage(i, 3, "0", "Has sido desalojado de su alquiler, por no pagar la electricidad!");
							}
							else
							{
								// RemoveDuenoOfHouse(houseid);
								// SendInfoMessage(i, 3, "0", "A perdido su casa por no pagar la electricidad!");
								SendInfoMessage(i, 3, "0", "Ahora tiene deuda por no pagar los impuestos de la casa!");
							}
						}
					}
					//Negocio
					if(PlayersData[i][Negocio])
					{
						impuestosNegocio = floatdiv(floatmul(NegociosData[PlayersData[i][Negocio]][Precio], alicuotaNegocios), 100);
						impuestos += impuestosNegocio;
						FaccionData[GOBIERNO][Deposito] = FaccionData[GOBIERNO][Deposito] + floatround(impuestosNegocio);

						format(MensajeBanco[3], 70, "{"COLOR_ROJO"}-{"COLOR_VERDE"}$%i", floatround(impuestosNegocio));
						SendInfoMessage(i, 1, MensajeBanco[3], "Negocio: ");
					}
					//Vehiculo
					if ( PlayersData[i][Car] != -1 )
					{
						impuestosVehiculo = floatdiv(floatmul(coches_Todos_Precios[GetVehicleModel(PlayersData[i][Car] - 400)], alicuotaVehiculos), 100);
						impuestos += impuestosVehiculo;
						FaccionData[GOBIERNO][Deposito] = FaccionData[GOBIERNO][Deposito] + floatround(impuestosVehiculo);
						format(MensajeBanco[3], 70, "{"COLOR_ROJO"}-{"COLOR_VERDE"}$%i", floatround(impuestosVehiculo));
						SendInfoMessage(i, 1, MensajeBanco[3], "Vehiculo: ");

						if ( impuestos > PlayersData[i][Banco] )
						{
							// RemoveDuenoOfVehicle(PlayersData[i][Car], 2);
							// SendInfoMessage(i, 3, "0", "Has perdido tu vehiculo por no pagar los impuestos!");
							SendInfoMessage(i, 3, "0", "Ahora tiene deuda por no pagar los impuestos del vehiculo!");
						}
					}
					//Cobrar Impuestos
					if(impuestos)
					{
						PlayersData[i][Banco] -= floatround(impuestos, floatround_tozero);

						format(MensajeBanco[3], 70, "Impuestos totales: {"COLOR_ROJO"}-{"COLOR_VERDE"}$%i", floatround(impuestos, floatround_tozero));
						format(MensajeBanco[4], 70, "Balance Final: $%i", PlayersData[i][Banco]);
						if(impuestos <= (paga + Intereses))
						format(MensajeBanco[4], 70, "%s (+$%i)", MensajeBanco[4], (paga + Intereses) - floatround(impuestos, floatround_tozero));
						else
						format(MensajeBanco[4], 70, "%s (-$%i)", MensajeBanco[4], floatround(impuestos, floatround_tozero) - (paga + Intereses));
						SendInfoMessage(i, 1, "", MensajeBanco[3]);
						SendInfoMessage(i, 1, MensajeBanco[4], "Banco: ");

					}
				}
    			SendInfoMessage(i, 1, " ", "|_____________________ Fin ____________________|");
				IncrementWorkHours(i);
				PlayersData[i][HoursPlaying]++;
				if(Accion == 1)
				{
					PlayersData[i][IsPaga] = 0;
					PlayersDataOnline[i][IsPagaO] = TimeNow;
				}
				SetPlayerScore(i, GetPlayerScoreEx(i));
				GetPlayerPos(i, Xpaga, Ypaga, Zpaga);
			    PlayerPlaySound(i, 1133, Xpaga, Ypaga, Zpaga);
			    SetPlayerOrginalTime(i);
			}
			else
			{
			    if ( PlayersDataOnline[i][State] == 3 )
			    {
    				SendInfoMessage(i, 0, "215", "No has jugado lo suficiente como para recibir la paga.");
   				}
			}
		}
		if(Accion == 1)
		{
			VerificarCochesVencidos();
			RandomFire();
		}
	}
	return 1;
}

ResetServer()
{
	OnGameModeExitEx();
	ResetGM = true;
	SendRconCommand("gmx");
    for ( new i = 0; i < 10; i++)
    {
    	SendClientMessageToAll(0xFFFFFFFF, " ");
	}
	SendClientMessageToAll(COLOR_MESSAGES[2], "{"COLOR_ROJO"}Atencion: {"COLOR_VERDE"}En estos momentos el servidor esta reiniciando, {"COLOR_ROJO"}POR FAVOR NO SE DESCONECTE! {"COLOR_VERDE"}Solo demorara 5 segundos.");
	SendClientMessageToAll(COLOR_MESSAGES[2], ReasonReset);
   	SendClientMessageToAll(0xFFFFFFFF, " ");
	SendClientMessageToAll(COLOR_MESSAGES[2], "{"COLOR_CREMA"}Saludos Cordiales,");
	SendClientMessageToAll(COLOR_MESSAGES[2], "{"COLOR_CREMA"}Equipo de "SERVER_NAME".");
	GameTextForAll( "~G~Servidor Reiniciando...~N~Por favor espere...", 6000, 0);
}

OnGameModeExitEx()
{
	for (new i = 0; i < MAX_PLAYERS; i++)
	{
		if ( IsPlayerConnected(i) )
		{
	    	SaveDatosPlayerDisconnect(i);
			// guardar estado tambien en la API si esta habilitada
			if ( UsersApi_IsEnabled() )
			{
				usersApi_SaveCharacter(i);
			}
    	}
	}
	// Negocios
	for (new i = 1; i < MAX_BIZZ_COUNT; i++)
	{
		DataSaveBizz(i, false);
	}
	// Teles
	for (new i=0; i!=MAX_TELES_COUNT; i++)
	{
	    if (Teles[i][PickupID] == 0) continue;
	    SaveTele(i, false);
	}
	// Otros
	// SaveMapeos
	for(new i=0; i != MAX_MAPEOS_COUNT; i++){
		if(!Mapeo[i][Modelo]) continue;
		SaveMapeo(i);
	}
	printf("[%s]: Mapeos Guardados!", DIR_MAPEOS_DB);

	//SaveGasolinera
	for (new i; i != MAX_GASOLINERAS_COUNT; i++)
	{
		SaveGasolinera(i);
	}
	printf("[%s]: Gasolineras Guardadas!", DIR_GASOLINERAS);

	SaveIncendios();
	// Save Car's
	for (new i = 0; i < MAX_CAR; i++)
	{
	    GetVehiclePos(DataCars[i][VehicleID], DataCars[i][PosX], DataCars[i][PosY], DataCars[i][PosZ]);
		GetVehicleZAngle(DataCars[i][VehicleID], DataCars[i][PosZZ]);
		DataCars[i][Interior] = GetVehicleInterior(DataCars[i][VehicleID]);
		DataCars[i][World]    = GetVehicleVirtualWorld(DataCars[i][VehicleID]);
	    GetVehiclePos(DataCars[i][VehicleID], DataCars[i][LastX], DataCars[i][LastY], DataCars[i][LastZ]);
		GetVehicleZAngle(DataCars[i][VehicleID], DataCars[i][LastZZ]);
		GetVehicleDamageStatus(DataCars[i][VehicleID], DataCars[i][PanelS], DataCars[i][DoorS], DataCars[i][LightS], DataCars[i][TiresS]);
		if ( DataCars[i][LlenandoGas] )
		{
            DataCars[i][Gas] = DataCars[i][LlenandoGas];
		}
		SaveDataVehicle(i);
	}
	SaveImpuestos();

	DestroyAllDynamicObjects();

	mysql_close(dataBase);
	print("___________________ GAMEMODE DESCARGADO CORRECTAMENTE! ___________________");
	print("___________________ GAMEMODE DESCARGADO CORRECTAMENTE! ___________________");
	print("___________________ GAMEMODE DESCARGADO CORRECTAMENTE! ___________________");
}

SetPlayerOrginalTime(playerid)
{
	new HourA, MinutesA;
	gettime(HourA, MinutesA);
	SetPlayerTime(playerid, GetOriginalHours(HourA), GetOriginalMinute(MinutesA));
}

GetOriginalHours(hour)
{
	if ( hour == 24 )
	{
	    return 0;
	}
	else if ( !hour )
	{
	    return 1;
	}
	else
	{
	    return hour;
	}
}

GetOriginalMinute(minute)
{
	if ( minute == 60 )
	{
	    return 0;
	}
	else if ( !minute )
	{
	    return 1;
	}
	else
	{
	    return minute;
	}
}

ApplyPlayerAnimCustom(playerid, const animlib[], const animid[], loop)
{
	if ( loop )
	{
		ApplyAnimation(playerid,animlib,animid, 4.0, true, true, true, true, true, SYNC_ALL);
		ApplyAnimation(playerid,animlib,animid, 4.0, true, true, true, true, true, SYNC_ALL);
		ApplyAnimation(playerid,animlib,animid, 4.0, true, true, true, true, true, SYNC_ALL);
		ApplyAnimation(playerid,animlib,animid, 4.0, true, true, true, true, true, SYNC_ALL);
	}
	else
	{
		ApplyAnimation(playerid,animlib,animid, 4.0, false, true, true, true, true, SYNC_ALL);
		ApplyAnimation(playerid,animlib,animid, 4.0, false, true, true, true, true, SYNC_ALL);
		ApplyAnimation(playerid,animlib,animid, 4.0, false, true, true, true, true, SYNC_ALL);
		ApplyAnimation(playerid,animlib,animid, 4.0, false, true, true, true, true, SYNC_ALL);
	}
	PlayersDataOnline[playerid][InAnim] = true;
}

