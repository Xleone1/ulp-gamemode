			new bizzModel = PlayersDataOnline[playerid][SaveAfterAgenda][1];
			new option = PlayersDataOnline[playerid][SaveAfterAgenda][2];
			if(!NegociosModelos[bizzType][bizzModel][InteriorId]) return Error(playerid, "El modelo de negocio que estaba editando ya no existe!");
			if(response){
				new string[128];
				if(option == 0){//Nombre
					if(strlen(inputtext) >= 2 && strlen(inputtext) <= MAX_PLAYER_NAME){
						ImportanteEx(playerid, "Renombaste el interior \"%s\" por \"%s\"", NegociosModelos[bizzType][bizzModel][TypeName], inputtext);
						format(NegociosModelos[bizzType][bizzModel][TypeName], MAX_PLAYER_NAME, "%s", inputtext);
						SaveDataBizzModel(bizzType, bizzModel);
					}
					else{
						ShowPlayerBizzTypesModelsOptions(playerid, bizzType, bizzModel, option);
						SendInfoMessage(playerid, 0, "", "El nombre del interior debe ser entre 2 y 24 caracteres!");
						return 1;
					}
				}
				else if(option == 1 ){
					ShowBizzModelsOptsSub(playerid, bizzType, bizzModel, 0, listitem);
					return 1;
				}
				else if(option == 2){
					ShowBizzModelsOptsSub(playerid, bizzType, bizzModel, 1, listitem);
					return 1;
				}
				else if(option == 3){
					new count;
					new bizzID[MAX_BIZZ_COUNT];
					for( new i; i!=MAX_BIZZ_COUNT; i++ ){
						if( NegociosData[i][Type] == bizzType+1 && NegociosData[i][NModel] == bizzModel+1 ){
							bizzID[count] = i;
							count++;
						}
					}
					if( count ){
						format(string, sizeof(string), "Se encontraron %d negocios %s con este interior programado: ", count, NegociosTipo[bizzType]);
						for( new i; i!=count; i++ ){
							if( (strlen(string) + 5) > 128 ){
								Error(playerid, "%s", string);
								format(string, sizeof(string), "? ");
							}
							if(count < count-1)
							format(string, sizeof(string), "%s%d, ", string, bizzID[i]);
							else
							format(string, sizeof(string), "%s%d", string, bizzID[i]);
						}
						Error(playerid, "%s", string);
					}
					else{
						ImportanteEx(playerid, "Eliminaste el interior de negocio %s[%d] tipo %s[%d]", NegociosModelos[bizzType][bizzModel][TypeName], bizzModel+1, NegociosTipo[bizzType], bizzType+1);
						NegociosModelos[bizzType][bizzModel][PosInX] = 0.0;
						NegociosModelos[bizzType][bizzModel][PosInY] = 0.0;
						NegociosModelos[bizzType][bizzModel][PosInZ] = 0.0;
						NegociosModelos[bizzType][bizzModel][PosInZZ] = 0.0;
						NegociosModelos[bizzType][bizzModel][PosInX_PC] = 0.0;
						NegociosModelos[bizzType][bizzModel][PosInY_PC] = 0.0;
						NegociosModelos[bizzType][bizzModel][PosInZ_PC] = 0.0;
						format(NegociosModelos[bizzType][bizzModel][TypeName], 24, "");

						new pickupid = NegociosModelos[bizzType][bizzModel][PickupId];
						if(IsValidDynamicPickup(pickupid)) DestroyDynamicPickup(pickupid);
						PickupIndex[pickupid][Tipo] = PICKUP_TYPE_NINGUNO;
						PickupIndex[pickupid][Tipoid] = 0;
						NegociosModelos[bizzType][bizzModel][PickupId] = 0;

						SaveDataBizzModel(bizzType, bizzModel);
						NegociosModelos[bizzType][bizzModel][InteriorId] = 0;
						mysql_format(dataBase, string, sizeof(string), "UPDATE `%s` SET `InteriorId`='0' WHERE TypeOfBizz=%i AND Model_ID=%i;", DIR_NEGOCIOS_TYPE, bizzType, bizzModel);
						mysql_query(dataBase, string, false);
						return 1;
					}
				}
			}
			ShowPlayerBizzTypesModels(playerid, bizzType, bizzModel);
			return 1;
		}
