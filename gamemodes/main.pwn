						        if ( !DataCars[vehicleIndex][LlenandoGas] )
						        {
									if ( DataCars[vehicleIndex][Gas] + 20 <= MAX_GAS_VEHICLE )
									{
										if ( gettime() - PlayersDataOnline[playerid][TimeLata] >= 60 )
										{
											if ( !DataCars[vehicleIndex][StateEncendido] )
											{
												DataCars[vehicleIndex][Gas] = DataCars[vehicleIndex][Gas] + 20;
												PlayersData[playerid][Lata] = false;
												PlayersDataOnline[playerid][TimeLata] = gettime();

												

												Acciones(playerid, 8, "echa el gas de su lata en el deposito del vehiculo");
					                            SendInfoMessage(playerid, 3, "0", "Ha echado el gas de su lata en este vehiculo");
				                            }
											else
