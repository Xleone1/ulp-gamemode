											player_pos_y,
											player_pos_z);

											GetPlayerPos(playerid, player_pos_x, player_pos_y, player_pos_z);
											PlayerPlaySound(playerid, 1002,
											player_pos_x,
											player_pos_y,
											player_pos_z);
						            		return 1;
						            	}
