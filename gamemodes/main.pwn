						SendInfoMessage(playerid, 0, "849", "Tu no tienes acceso a el comando /Silenciar.");
					}
				}
				// /Tutorial [ID]
				else if (strfind(cmdtext, "/Tutorial", true) == 0 && (cmdtext[9] == ' ' || cmdtext[9] == '\0'))
