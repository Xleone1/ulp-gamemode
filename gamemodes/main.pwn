								{
									new SlotIDGet = -1;
									for (new i = 0; i < MAX_GUANTERA_GAVETA_SLOTS; i++)
									{
										if ( HouseData[houseID][GavetaObjects][i] )
										{
											SlotIDGet = i;
											break;
										}
									}
									if ( SlotIDGet != -1 )
									{
										new saveType = GetObjectByType(playerid, GetTypeObjectEx(HouseData[houseID][GavetaObjects][SlotIDGet]));
										if ( saveType == -1 )
