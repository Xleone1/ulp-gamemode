																    format(MsgLlenarDeposito, sizeof(MsgLlenarDeposito), "Mando a llenar el deposito del vehiculo por $%i", (GasToFill * precioCombustible));

															        GivePlayerMoneyEx(playerid, -(GasToFill * precioCombustible));

																    Gasolineras[MyNearGas][Fuel] = Gasolineras[MyNearGas][Fuel] - GasToFill;
																	SaveGasolinera(MyNearGas);

																	FaccionData[GOBIERNO][Deposito] = FaccionData[GOBIERNO][Deposito] + (GasToFill * precioCombustible);

																	Acciones(playerid, 8, "comienza a llenar el deposito del vehiculo");
										                            SendInfoMessage(playerid, 3, "0", MsgLlenarDeposito);

																	DataCars[vehicleIndex][LlenandoGas] = DataCars[vehicleIndex][Gas] + GasToFill;
																	FillVehicleGas(vehicleIndex);

