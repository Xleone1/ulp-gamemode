								new MyWeapons, MyAmmo; MyWeapons = GetPlayerWeapon(playerid); MyAmmo = GetPlayerAmmo(playerid);
						        if ( CheckWeapondCheat(playerid) && MyWeapons != 0 )
						        {
									new EmpySlot = -1;
									for (new i = 0; i < 7; i++)
									{
									    if ( coches_Todos_Maleteros[MyMalteroOpen][i][0] == 0 )
									    {
		                                    EmpySlot = i;
											break;
