				  	else if (strfind(cmdtext, "/Vender Coche", true) == 0)
				    {   
						if ( PlayersData[playerid][Faccion] == NFS && PlayersData[playerid][Rango] <= 2)
						{
							new buyerId;
							if (sscanf(cmdtext[13], "u", buyerId)) 
								return SendSyntaxError(playerid, "Vender Vehiculo", "/Vender Vehiculo [ID del jugador]");

							new MyNearCar = IsPlayerInNearVehicle(playerid);
							if ( MyNearCar)
							{
								new vehicleIndex = GetVehicleIndexByVehicleID(MyNearCar);
								if (IsVehicleHasOwner(vehicleIndex)) return SendInfoMessage(playerid, 0, "230", "Este vehiculo ya tiene dueÄo!");
								
								new PriceCar = GetVehiclePrice(vehicleIndex);
								if ( PlayersData[playerid][Dinero] >= PriceCar / 3 )
								{
									if ( IsPlayerNearEx(playerid, buyerId,
											"225",
											"226",
											"227",
											"El jugador que desea venderle un vehiculo no se encuentra conectado",
											"El jugador que desea venderle un vehiculo no se encuentra logueado",
											"El jugador que desea venderle un vehiculo no se encuentra cerca de ti") )
									{
										new vehicleName[MAX_PLAYER_NAME];
										GetVehicleName(vehicleIndex, vehicleName, sizeof(vehicleName));

										new MsgToComprador[MAX_TEXT_CHAT], MsgToVendedor[MAX_TEXT_CHAT];
										format(MsgToComprador, sizeof(MsgToComprador),
											"El vendedor de vehiculos %s, quiere venderte un vehiculo modelo \"%s\" por $%i, Usa (/Aceptar Coche)",
											PlayersDataOnline[playerid][NameOnlineFix], vehicleName, PriceCar);

										format(MsgToVendedor, sizeof(MsgToVendedor),
											"Ofreciste vender un vehiculos modelo \"%s\", a %s por $%i",
											vehicleName, PlayersDataOnline[buyerId][NameOnlineFix], PriceCar);

										SendInfoMessage(buyerId, 3, "0", MsgToComprador);
										SendInfoMessage(playerid, 3, "0", MsgToVendedor);

										PlayersDataOnline[buyerId][VCoche][0] = playerid;
										PlayersDataOnline[buyerId][VCoche][1] = vehicleIndex;
									}
								}
								else
								{
									SendInfoMessage(playerid, 0, "234", "No tienes suficiente dinero para tramitar los papeles de este vehiculo!");
								}
							}
						}
						else
						{
							SendInfoMessage(playerid, 0, "229", "No eres vendedor de vehiculos!");
