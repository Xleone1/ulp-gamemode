						        {
							        coches_Todos_Maleteros[MyMalteroOpen][8][0] = coches_Todos_Maleteros[MyMalteroOpen][8][0] + strval(cmdtext[14]);
							        PlayersData[playerid][Drogas] = PlayersData[playerid][Drogas] - strval(cmdtext[14]);

