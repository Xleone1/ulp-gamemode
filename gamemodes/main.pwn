			    	    if (PlayersData[playerid][Mapper])
						SendInfoMessage(playerid, 0, "", "QuizĂˇs quiso decir: /Info {GarageC, Tele, Garage}");
						
						SendInfoMessage(playerid, 0, "", "QuizĂˇs quiso decir: /Info {Negocio, Casa}");
					}
