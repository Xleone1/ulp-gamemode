		        {
		            if ( IsObjectInBolsillo(playerid, 4) ) return Error(playerid, "Ya usted tiene una agenda");
		            if ( IsNotFullBolsillo(playerid, playerid, "Usted tiene los bolsillos llenos!") )
		            {
						AddObjectBolsillo(playerid, 4);
						Importante(playerid, "Has comprado una Agenda por $%i.", M24_7_Precios[listitem]);
  					    CleanSMS(playerid); SavePlayerSMS(playerid);
			            CleanAgenda(playerid);
					}
					else return 1;
		        }
		        else if (listitem == 3)//Flores
		        {
		            GivePlayerWeaponEx(playerid, 14, 1);
					Importante(playerid, "Has comprado unas flores por $%i.", M24_7_Precios[listitem]);
		        }
		        else if (listitem == 4)//Comprar Saldo
		        {
		            ShowPlayerDialogEx(playerid, 30, DIALOG_STYLE_INPUT, "{"COLOR_AZUL"}Seleccione el monto de saldo a comprar", "{"COLOR_TEXTO_DIALOGS"}Cuanto desea comprar de saldo para su movil?", "Comprar", "Volver");
		            return 1;
		        }
		        else if (listitem == 5)//Bolsa
		        {
		            if ( PlayersData[playerid][HaveBolsa] ) return Error(playerid, "Ya usted tiene una bolsa");
					PlayersData[playerid][HaveBolsa] = true;
					CleanArticulosBolsa(playerid);
					Importante(playerid, "Has comprado una Bolsa por $%i.", M24_7_Precios[listitem]);
		        }
		        else if (listitem == 6)//Condones
		        {
		            if ( IsNotFullCartera(playerid, playerid, "Usted tiene la cartera llena!") )
		            {
						AddObjectToCartera(playerid, CARTERA_TYPE_CONDONES, 3, 0, 0);
						Importante(playerid, "Has comprado unos Condones por $%i.", M24_7_Precios[listitem]);
					}
					else return 1;
		        }
		        else if (listitem == 7)//Maleta
		        {
		            if ( GetObjectByType(playerid, TYPE_MALETIN) == -1 )
		            {
						Importante(playerid, "Has comprado un maletin por $%i.", M24_7_Precios[listitem]);
						AddObjectHoldToPlayer(playerid, 1210);
					}
					else return Error(playerid, "Tienes las manos ocupadas, no puedes llevar mas nada en ellas!");
		        }
				SetMoneyExtorsion(bizzid, M24_7_Precios[listitem]);
				GivePlayerMoneyEx(playerid, -M24_7_Precios[listitem]);
				
				ShowDialog247(playerid);
		    }
		    else
		    {
			    Error(playerid, "Este negocio no tiene materiales!");
		    }
		}
