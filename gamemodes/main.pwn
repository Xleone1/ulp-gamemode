									new MsgDejar[MAX_TEXT_CHAT];
							        format(MsgDejar, sizeof(MsgDejar), "Has dejado %i materiales en el almacen.", CantidadItem);
							        Acciones(playerid, 8, "ha dejado materiales en el almacen");
