//				MACROS

#define function%0(%1) forward %0(%1); public %0(%1)

#define Error(%0,%1) SendClientMessage(%0, 0xFFA97FFF, "Error: "%1)
#define Info(%0,%1) SendClientMessage(%0, 0xC8C8C8CD, "Info: "%1)
#define Ayuda(%0,%1) SendClientMessage(%0, 0xFFD97FFF, %1)
#define Importante(%0,%1) SendClientMessage(%0, 0x33CCFFFF, "Importante: "%1)
#define ImportanteEx(%0,%1) SendClientMessage(%0, 0x33CCFFFF, "Administracion: "%1)
#define Advise(%0,%1) SendClientMessage(%0, 0x8C8C8CFF, "Administracion: "%1)

//				HOOKS		

Cache:mysql_queryEx(MySQL:handle, const query[], bool:use_cache = true)
{
	new Cache:cache_id = mysql_query(handle, query, use_cache);

	new errorid = mysql_errno(handle);
	if( errorid ){
		new error[200];
		mysql_error(error, sizeof(error), handle);
		printf(" ");
		printf("[mysql-error]: Errorid: #%d", errorid);
		printf("[mysql-error]: Query: '%s'", query);
		printf("[mysql-error]: Error: '%s'", error);
		printf(" ");
	}
	return Cache:cache_id;
}
#if defined _ALS_mysql_query
	#undef mysql_query
#else
	#define _ALS_mysql_query
#endif
#define mysql_query mysql_queryEx

