					alicuotaNegocios = PlayersDataOnline[playerid][pAlicuotas][1];
				}
				if(PlayersDataOnline[playerid][pAlicuotas][2] != alicuotaVehiculos)
				{
					format(string, sizeof(string), "Impuesto Vehiculos. Antes: %.4f %% | Ahora: %.4f %%", alicuotaVehiculos, PlayersDataOnline[playerid][pAlicuotas][2]);
					format(stringA, sizeof(stringA), "%s[%i] cambio el impuesto Vehiculos. Antes: %.4f %% | Ahora: %.4f %%", PlayersDataOnline[playerid][NameOnline], playerid, alicuotaVehiculos, PlayersDataOnline[playerid][pAlicuotas][2]);
					SendInfoMessage(playerid, 3, "", string);
					MsgCheatsReportsToAdmins(stringA);
					alicuotaVehiculos = PlayersDataOnline[playerid][pAlicuotas][2];
				}
				if(PlayersDataOnline[playerid][pPrecioPeaje] != precioPeajesParqueos)
				{
					format(string, sizeof(string), "Peajes y Parqueos. Antes: $%d | Ahora: $%d", precioPeajesParqueos, PlayersDataOnline[playerid][pPrecioPeaje]);
					format(stringA, sizeof(stringA), "%s[%i] cambio el precio de Peajes y Parqueos. Antes: $%d | Ahora: $%d", PlayersDataOnline[playerid][NameOnline], playerid, precioPeajesParqueos, PlayersDataOnline[playerid][pPrecioPeaje]);
					SendInfoMessage(playerid, 3, "", string);
					MsgCheatsReportsToAdmins(stringA);
					precioPeajesParqueos = PlayersDataOnline[playerid][pPrecioPeaje];
				}
				if(PlayersDataOnline[playerid][pPrecioCombustible] != precioCombustible)
				{
					format(string, sizeof(string), "Combustible. Antes: $%d | Ahora: $%d", precioCombustible, PlayersDataOnline[playerid][pPrecioCombustible]);
					format(stringA, sizeof(stringA), "%s[%i] cambio el precio del Combustible. Antes: $%d | Ahora: $%d", PlayersDataOnline[playerid][NameOnline], playerid, precioCombustible, PlayersDataOnline[playerid][pPrecioCombustible]);
					SendInfoMessage(playerid, 3, "", string);
					MsgCheatsReportsToAdmins(stringA);
					precioCombustible = PlayersDataOnline[playerid][pPrecioCombustible];
				}
				SaveImpuestos();
			}
			else ShowEditarImpuestos(playerid);
			return 1;
		}
	}
	//// END DIALOGS
	return 1;
}

public OnPlayerCommandText(playerid, cmdtext[])
{
    // --- ANTI-FLOOD COMMANDS ---
    if ( PlayersDataOnline[playerid][FloodMuteTime] > gettime() )
    {
        new str[128];
        format(str, sizeof(str), "Estas bloqueado por spam. Por favor espera %d segundos.", PlayersDataOnline[playerid][FloodMuteTime] - gettime());
        SendClientMessage(playerid, 0xFFA97FFF, str);
        return 1;
    }
    new tick = GetTickCount();
    if ( tick - PlayersDataOnline[playerid][LastCmdTime] < 1000 )
    {
        PlayersDataOnline[playerid][CmdSpamCount]++;
        if ( PlayersDataOnline[playerid][CmdSpamCount] >= 4 )
        {
            PlayersDataOnline[playerid][FloodMuteTime] = gettime() + 15;
            Error(playerid, "Has sido bloqueado por 15 segundos por hacer spam de comandos.");
            return 1;
        }
    }
    else
    {
        PlayersDataOnline[playerid][CmdSpamCount] = 0;
    }
    PlayersDataOnline[playerid][LastCmdTime] = tick;
    // --- END ANTI-FLOOD ---
    if (strfind(cmdtext, InvalidSting, true) != -1) return SendInfoMessage(playerid, 0, "1380", "Ha introducido un caracter invĂˇlido.");
	new LenGet = strlen(cmdtext);
	for ( new i = 0; i < LenGet; i++ )
	{
	    if ( cmdtext[i] == '}' || cmdtext[i] == '{' )
	    {
	        cmdtext[i] = ' ';
	    }
	}
	if (PlayersDataOnline[playerid][State] == 3 && PlayersDataOnline[playerid][IsNotSilenciado])
	{
	    if ( !PlayersDataOnline[playerid][InCamera] )
	    {
		    if ( strlen(cmdtext) > 1 )
		    {
		    	printf("%s[%i] || %s", PlayersDataOnline[playerid][NameOnline], playerid, cmdtext);

		        PlayersDataOnline[playerid][IsAFK] = false;

				if( OnPlayerCommandVehicles(playerid, cmdtext) ) return 1;
				else if( OnPlayerCommandHouse(playerid, cmdtext) ) return 1;
				else if( OnPlayerCommandBusiness(playerid, cmdtext) ) return 1;
				else if( OnPlayerCommandJobs(playerid, cmdtext) ) return 1;

				// COMANDO: /Ayuda
				else if( strfind(cmdtext, "/Ayuda", true) == 0)
				{	
				  	if (strcmp("/Ayuda", cmdtext, true, 6) == 0 && strlen(cmdtext) == 6)
			    	{
					    SendClientMessage(playerid, COLOR_TITULO_DE_AYUDA, TITULO_AYUDA);
	      				SendOutput(playerid, 1, "Principales: ","/Copyright - /Reglas - /Duda - /Stats - /Impuestos - /Cuenta - /Hora - /Hablar - /Caminar -  /Reportar o /Re");
					    SendOutput(playerid, 1, "Info Extra: ","/Ayuda {Basicos, Canales, faccion, Rangos, Banco, Crear, Coche, Movil, Casa, Negocio, Estados, Dar, Coger, Dejar, Usar, Otros}");
					    SendOutput(playerid, 1, "Info Extra: ","/Ayuda {Idiomas, Trabajo, Radio, Tirar, Movil, Luces, Canales, Aceptar, Llaves, DeathMatch, Carreras, Animaciones 1 - 3}");
						SendOutput(playerid, 1, " ", "Para Mas informaciĂłn visite nuestros foros en "URL_WEB". Use /Duda o puede whisper a un admin con /W [ID] [Duda] (Ver /Staff)");
			    	}
			    	// COMANDO: /Ayuda Canales
				  	else if( strcmp("/Ayuda Basicos", cmdtext, true, 14) == 0 && strlen(cmdtext) == 14 || 
